build_host/
build_local/
# cmake build directories
**/cmake_build/
**/cmake_build_*/
**/Build/build/
# prebuilt outputs that are regenerated by build scripts — keep Depend/ tracked
libsys/Build/build/

# build artifacts — but NOT Depend/ (those are source deps, not generated)
*.exe
*.obj
*.o
*.dll
*.lib
*.log
# exclude build-generated binaries but keep Depend/ prebuilt libs
*.a
*.so
!Depend/**
.vs/
.vscode/
